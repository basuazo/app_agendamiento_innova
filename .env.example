# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/cowork_db"

# JWT
JWT_SECRET="supersecretkey_change_in_production_min_32_chars"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
CLIENT_URL="http://localhost:5173"

# Google Calendar (Service Account)
# Obtener de Google Cloud Console → IAM → Service Accounts
GOOGLE_CALENDAR_ID="your-calendar-id@group.calendar.google.com"
GOOGLE_SERVICE_ACCOUNT_EMAIL="cowork-app@your-project.iam.gserviceaccount.com"
# El private key debe tener \n como saltos de línea reales en el .env
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
